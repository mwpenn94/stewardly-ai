# ═══════════════════════════════════════════════════════════════════
# Stewardly AI — Environment Variables
# Copy to .env and fill in values before starting the application.
# ═══════════════════════════════════════════════════════════════════

# ─── Required ─────────────────────────────────────────────────────

# JWT secret for signing session tokens (must be a strong random string)
JWT_SECRET=

# MySQL-compatible database connection URL
DATABASE_URL=mysql://user:password@host:3306/stewardly

# Manus application ID
VITE_APP_ID=

# ─── Authentication ──────────────────────────────────────────────

# Manus OAuth server base URL
OAUTH_SERVER_URL=

# Owner's open ID (platform admin)
OWNER_OPEN_ID=

# Google OAuth (optional, for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth (optional, for social login)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Security ────────────────────────────────────────────────────

# Dedicated encryption key for integration credentials (hex-encoded 32 bytes / 64 chars)
# If not set, falls back to JWT_SECRET (production requires either this or JWT_SECRET)
INTEGRATION_ENCRYPTION_KEY=

# Comma-separated list of allowed CORS origins (e.g., https://app.stewardly.ai)
# If not set, same-origin policy is enforced in production
ALLOWED_ORIGINS=

# ─── AI / LLM ───────────────────────────────────────────────────

# Forge API for multi-model LLM integration
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Integrations ───────────────────────────────────────────────

# SnapTrade (investment data)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# ─── Runtime ─────────────────────────────────────────────────────

# Application port (default: 3000)
PORT=3000

# Environment (development | production)
NODE_ENV=development
